# Copy to .env.local and fill in your values.
# These vars are also required in Vercel Project Settings → Environment Variables.

# MapTiler key — enables Korean labels everywhere on the map.
# Free tier (100k req/month) is enough for personal use.
# Sign up: https://www.maptiler.com/cloud/
# Without this key, the map falls back to OSM (local-language labels).
NEXT_PUBLIC_MAPTILER_KEY=
